{
  "_comment": "Model overrides for agents. Layer defaults apply first, then per-agent overrides win. Provider names must match librechat-user.yaml endpoint names. Remove this file or use --no-model-overrides to use agents.json built-in defaults.",
  "_budget_notes": {
    "Groq":          "30 RPM, ~500K tok/day (70B), 14.4K RPD — workhorse, fast",
    "Cerebras":      "1M tok/day, 30 RPM, 8K ctx free — workhorse, fastest",
    "Gemini":        "Flash 10 RPM / 250 RPD, Pro 5 RPM / 100 RPD — quality but daily caps",
    "GitHub Models": "10 RPM / 50 RPD (high-end), ~150 RPD (small) — moderate",
    "Mistral":       "1B tok/month, all models, but only 2 RPM — low-frequency only",
    "Cohere":        "20 RPM, 1K req/month (~33/day) — very low volume",
    "OpenRouter":    "20 RPM / 50 RPD (:free models, no credits) — very low volume",
    "Qwen":          "1M tokens/model, 90-day grant, then paid — prototyping only"
  },
  "defaults": {
    "L1":      {"provider": "Groq",     "model": "llama-3.3-70b-versatile"},
    "utility": {"provider": "Groq",     "model": "llama-3.1-8b-instant"},
    "L2":      {"provider": "Gemini",   "model": "gemini-2.5-flash"},
    "L3":      {"provider": "Gemini",   "model": "gemini-2.5-pro"},
    "L4":      {"provider": "Cerebras", "model": "qwen-3-235b-a22b-instruct-2507"},
    "L5":      {"provider": "GitHub Models", "model": "gpt-4o-mini"}
  },
  "agents": {
    "_design": "Core (10 agents) uses high-budget providers: Groq, Cerebras, Gemini. News (4 agents) uses low-budget providers: Cohere, OpenRouter, GitHub Models, Mistral — low call frequency (~2-4 articles/day each). Trading (2 agents) uses Cerebras + Groq for speed.",

    "market-data":     {"provider": "Groq",     "model": "llama-3.3-70b-versatile",        "_load": "~30 calls/day, tool-heavy scraping"},
    "osint-data":      {"provider": "Cerebras", "model": "qwen-3-235b-a22b-instruct-2507", "_load": "~20 calls/day, many MCP tools"},
    "signals-data":    {"provider": "Cerebras", "model": "qwen-3-235b-a22b-instruct-2507", "_load": "~20 calls/day, RSS/Reddit/HN tools"},

    "market-analyst":  {"provider": "Gemini",       "model": "gemini-2.5-flash",            "_load": "~10 calls/day, reasoning"},
    "osint-analyst":   {"provider": "Gemini",       "model": "gemini-2.5-flash",            "_load": "~10 calls/day, threat assessment"},
    "signals-analyst": {"provider": "GitHub Models", "model": "gpt-4o-mini",                "_load": "~10 calls/day, sentiment analysis"},

    "synthesizer":     {"provider": "Gemini",   "model": "gemini-2.5-pro",                  "_load": "~3 calls/day, highest reasoning"},

    "cron-planner":    {"provider": "Cerebras", "model": "qwen-3-235b-a22b-instruct-2507",  "_load": "~5 calls/day, planning + scheduling"},
    "cron-trading":    {"provider": "Groq",     "model": "llama-3.3-70b-versatile",         "_load": "~5 calls/day, trade execution"},

    "news-the-augur":       {"provider": "Cohere",        "model": "command-a-03-2025",     "_load": "~3 calls/day, EN general articles"},
    "news-der-augur":       {"provider": "Mistral",       "model": "mistral-small-latest",  "_load": "~3 calls/day, DE general articles — Mistral strong on European languages"},
    "news-financial-augur": {"provider": "OpenRouter",    "model": "minimax/minimax-m2.5:free",    "_load": "~3 calls/day, EN financial articles"},
    "news-finanz-augur":    {"provider": "GitHub Models", "model": "gpt-4o-mini",           "_load": "~3 calls/day, DE financial articles"},

    "live-chat":       {"provider": "anthropic", "model": "claude-sonnet-4-6",               "_load": "main chat agent, needs best reasoning — keep on Anthropic"},

    "trader":          {"provider": "Groq",     "model": "llama-3.3-70b-versatile",         "_load": "~15 calls/day, stateless broker ops, needs reliability"},
    "charter":         {"provider": "Groq",     "model": "llama-3.1-8b-instant",            "_load": "~15 calls/day, just calls store_chart, fastest/cheapest"}
  }
}
