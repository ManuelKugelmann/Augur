# LibreChat — Environment Configuration
# setup.sh auto-generates crypto keys on first install.
# You only need to fill in MONGO_URI and at least one LLM provider.

# ╔══════════════════════════════════════════════╗
# ║  EDIT THESE — required for LibreChat to run  ║
# ╚══════════════════════════════════════════════╝

# ── MongoDB (required) ─────────────────────────
# Free M0 cluster: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/LibreChat

# ── LLM Providers (at least one required) ──────
# All providers below work with LibreChat via OpenAI-compatible endpoints.
# Uncomment any key + its matching endpoint block in librechat.yaml.
# See docs/llm-keys.md for full setup guide.
#
# ANTHROPIC_API_KEY=sk-ant-...      # https://console.anthropic.com/settings/keys
# OPENAI_API_KEY=sk-...             # https://platform.openai.com/api-keys
# GROQ_API_KEY=gsk_...              # https://console.groq.com/keys             (free tier)
# GEMINI_API_KEY=AI...              # https://aistudio.google.com/apikey         (free tier)
# MISTRAL_API_KEY=...               # https://console.mistral.ai/api-keys       (free tier)
# CEREBRAS_API_KEY=csk-...          # https://cloud.cerebras.ai                 (free tier)
# COHERE_API_KEY=...                # https://dashboard.cohere.com/api-keys     (free tier)
# SAMBANOVA_API_KEY=...             # https://cloud.sambanova.ai                (free trial)
# HF_API_KEY=hf_...                 # https://huggingface.co/settings/tokens    (free tier)
# GITHUB_MODELS_PAT=ghp_...        # https://github.com/settings/tokens        (free, no scopes)
# DASHSCOPE_API_KEY=sk-...          # https://dashscope.console.aliyun.com/apiKey (Qwen, free tier)
# OPENROUTER_API_KEY=sk-or-...      # https://openrouter.ai/keys                (some free models)
#
# ── Endpoint visibility (optional) ───────────
# By default LibreChat shows ALL configured endpoints (built-in + custom).
# Uncomment to restrict which endpoints appear in the UI:
# ENDPOINTS=openAI,anthropic,custom
#
# ── Claude Max (subscription via CLIProxyAPI) ─
# Use your Claude Pro/Max subscription instead of API key billing.
# See docs/claude-token-wrapper.md for setup guide.

# ╔══════════════════════════════════════════════╗
# ║  PRESET — auto-generated or rarely changed   ║
# ╚══════════════════════════════════════════════╝

# Crypto keys — auto-generated by setup.sh, do not edit
CREDS_KEY=
CREDS_IV=
JWT_SECRET=
JWT_REFRESH_SECRET=

# Meilisearch disabled (not available on Uberspace)
SEARCH=false

# RAG API disabled (no Docker/vector DB on Uberspace).
# Explicitly empty to suppress "RAG API … at undefined" startup warning.
RAG_API_URL=

# ── Signals Stack ─────────────────────────────
# API keys and MONGO_URI_SIGNALS live in ~/augur/.env (not here).
# The trading server reads ~/augur/.env directly.
# See ~/augur/.env.example and docs/api-keys.md for reference.
